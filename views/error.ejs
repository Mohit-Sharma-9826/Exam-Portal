<%- include('layouts/header') %>

<div class="auth-page-container">
  <div class="auth-card error-card text-center" style="max-width: 500px;">
    <div class="error-icon text-danger" style="font-size: 4rem; margin-bottom: 1rem;">
      <i class="fa-solid fa-circle-exclamation"></i>
    </div>
    <h2 style="font-size: 2rem; margin-bottom: 0.5rem;"><%= statusCode %> - <%= title %></h2>
    <p class="text-muted" style="margin-bottom: 1.5rem;"><%= message %></p>
    
    <div class="flex justify-center gap-2">
      <% if (user) { %>
        <% if (user.role === 'admin') { %>
          <a href="/admin/dashboard" class="btn btn-primary"><i class="fa-solid fa-arrow-left"></i> Return to Admin Dashboard</a>
        <% } else { %>
          <a href="/student/dashboard" class="btn btn-primary"><i class="fa-solid fa-arrow-left"></i> Return to Student Dashboard</a>
        <% } %>
      <% } else { %>
        <a href="/auth/login" class="btn btn-primary"><i class="fa-solid fa-arrow-left"></i> Go to Student Login</a>
      <% } %>
    </div>
  </div>
</div>

<%- include('layouts/footer') %>
