<%- include('../layouts/header') %>
<%- include('../layouts/sidebar') %>

<div class="questions-admin-page">
  <div class="card glass-card mb-6">
    <div class="card-header border-bottom flex justify-between align-center flex-wrap gap-4">
      <div>
        <h3 class="card-title text-accent"><i class="fa-solid fa-folder-open"></i> Question Bank Repository</h3>
        <p class="subtext">Search, categorize, add, or bulk-import examination questions.</p>
      </div>
      <div class="actions-group flex gap-2">
        <button class="btn btn-primary" onclick="openQuestionModal('create')">
          <i class="fa-solid fa-plus-circle"></i> Add Question
        </button>
        <button class="btn btn-secondary" onclick="openImportModal()">
          <i class="fa-solid fa-file-upload"></i> Import CSV
        </button>
      </div>
    </div>

    <!-- Filters Row -->
    <div class="card-body bg-light-translucent">
      <form action="/admin/questions" method="GET" class="filter-search-form">
        <div class="filter-grid">
          <div class="form-group mb-0">
            <input type="text" name="search" placeholder="Search questions by text..." value="<%= filters.search %>" class="form-control">
          </div>
          <div class="form-group mb-0">
            <select name="subject" class="form-control">
              <option value="">-- All Subjects --</option>
              <% subjects.forEach(sub => { %>
                <option value="<%= sub %>" <%= filters.subject === sub ? 'selected' : '' %>><%= sub %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group mb-0 flex gap-2">
            <button type="submit" class="btn btn-primary"><i class="fa-solid fa-filter"></i> Apply</button>
            <a href="/admin/questions" class="btn btn-outline">Clear</a>
          </div>
        </div>
      </form>
    </div>
  </div>

  <!-- Questions Table Card -->
  <div class="card glass-card">
    <div class="card-body">
      <% if (questions && questions.length > 0) { %>
        <div class="table-responsive">
          <table class="data-table">
            <thead>
              <tr>
                <th style="width: 50%;">Question Details</th>
                <th>Subject</th>
                <th>Marks</th>
                <th>Neg Marks</th>
                <th>Correct Key</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% questions.forEach(q => { %>
                <tr>
                  <td>
                    <div class="q-row-info">
                      <p class="q-row-text"><strong><%= q.text %></strong></p>
                      <div class="q-row-options-snippet text-xs text-muted">
                        <span><strong>A:</strong> <%= q.options.A %></span> |
                        <span><strong>B:</strong> <%= q.options.B %></span> |
                        <span><strong>C:</strong> <%= q.options.C %></span> |
                        <span><strong>D:</strong> <%= q.options.D %></span>
                      </div>
                    </div>
                  </td>
                  <td><span class="subject-tag"><%= q.subject %></span></td>
                  <td><strong>+<%= q.marks %></strong></td>
                  <td><span class="<%= q.negativeMarks > 0 ? 'text-danger' : '' %>">-<%= q.negativeMarks %></span></td>
                  <td><span class="badge badge-success font-bold"><%= q.correctAnswer %></span></td>
                  <td>
                    <div class="actions-group flex gap-2">
                      <button class="btn btn-outline btn-xs" onclick="openQuestionModal('edit', '<%= q._id %>')">
                        <i class="fa-solid fa-pen-to-square"></i>
                      </button>
                      <button class="btn btn-danger btn-xs" onclick="deleteQuestion('<%= q._id %>')">
                        <i class="fa-solid fa-trash"></i>
                      </button>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="empty-state">
          <i class="fa-solid fa-circle-question"></i>
          <h4>No Questions Found</h4>
          <p>No questions matched your search criteria or the bank is empty.</p>
        </div>
      <% } %>
    </div>
  </div>
</div>

<!-- Add/Edit Question Modal Overlay -->
<div class="modal-overlay" id="question-modal" style="display: none;">
  <div class="modal-card modal-large">
    <div class="modal-header">
      <h3 id="modal-title">Add New MCQ</h3>
      <button class="modal-close" onclick="closeQuestionModal()">&times;</button>
    </div>
    
    <form id="question-form" method="POST">
      <div class="modal-body modal-scroll-body">
        <div class="form-group">
          <label for="text">Question Text</label>
          <textarea id="text" name="text" placeholder="Write the problem statement here..." rows="3" required></textarea>
        </div>

        <div class="options-inputs-grid mt-4">
          <div class="form-group">
            <label for="optionA">Option A</label>
            <input type="text" id="optionA" name="optionA" placeholder="Answer option A" required>
          </div>
          <div class="form-group">
            <label for="optionB">Option B</label>
            <input type="text" id="optionB" name="optionB" placeholder="Answer option B" required>
          </div>
          <div class="form-group">
            <label for="optionC">Option C</label>
            <input type="text" id="optionC" name="optionC" placeholder="Answer option C" required>
          </div>
          <div class="form-group">
            <label for="optionD">Option D</label>
            <input type="text" id="optionD" name="optionD" placeholder="Answer option D" required>
          </div>
        </div>

        <div class="form-grid mt-4">
          <div class="form-group">
            <label for="correctAnswer">Correct Option</label>
            <select name="correctAnswer" id="correctAnswer" class="form-control" required>
              <option value="">-- Choose Key --</option>
              <option value="A">Option A</option>
              <option value="B">Option B</option>
              <option value="C">Option C</option>
              <option value="D">Option D</option>
            </select>
          </div>

          <div class="form-group">
            <label for="marks">Marks Weight</label>
            <input type="number" id="marks" name="marks" min="1" value="1" placeholder="1" required>
          </div>

          <div class="form-group">
            <label for="negativeMarks">Negative Penalty Marks</label>
            <input type="number" id="negativeMarks" name="negativeMarks" step="0.25" min="0" value="0" placeholder="0">
          </div>

          <div class="form-group">
            <label for="subject">Subject / Category</label>
            <input type="text" id="subject" name="subject" placeholder="E.g. Web Development" required>
          </div>
        </div>
      </div>

      <div class="modal-footer flex justify-end gap-2">
        <button type="button" class="btn btn-outline" onclick="closeQuestionModal()">Cancel</button>
        <button type="submit" class="btn btn-primary" id="modal-submit-btn">Save MCQ</button>
      </div>
    </form>
  </div>
</div>

<!-- Import CSV Modal Overlay -->
<div class="modal-overlay" id="import-modal" style="display: none;">
  <div class="modal-card">
    <div class="modal-header">
      <h3>Import MCQ Database (CSV)</h3>
      <button class="modal-close" onclick="closeImportModal()">&times;</button>
    </div>
    
    <form id="import-form" onsubmit="handleCSVImport(event)">
      <div class="modal-body">
        <div class="alert alert-info">
          <h4 class="font-bold"><i class="fa-solid fa-circle-info"></i> CSV Formatting Schema</h4>
          <p class="text-xs mt-1">Columns must include headers (case-insensitive):</p>
          <code class="text-xs block bg-dark p-2 rounded mt-1 text-light">
            text, optionA, optionB, optionC, optionD, correctAnswer, marks, negativeMarks, subject
          </code>
          <p class="text-xs mt-1">Note: correctAnswer must be A, B, C, or D.</p>
        </div>

        <div class="form-group mt-4">
          <label for="csvFile">Choose CSV File:</label>
          <input type="file" id="csvFile" name="csvFile" accept=".csv" class="form-control" required>
        </div>
        
        <div id="import-feedback" style="display: none;" class="alert alert-success mt-2">
          <span>Parsing...</span>
        </div>
      </div>
      
      <div class="modal-footer flex justify-between">
        <button type="button" class="btn btn-outline" onclick="closeImportModal()">Cancel</button>
        <button type="submit" class="btn btn-primary" id="import-submit-btn">Upload & Seed <i class="fa-solid fa-seedling"></i></button>
      </div>
    </form>
  </div>
</div>

<script>
  const questionsList = <%- JSON.stringify(questions) %>;

  function openQuestionModal(mode, questionId = '') {
    const modal = document.getElementById('question-modal');
    const form = document.getElementById('question-form');
    const titleHeader = document.getElementById('modal-title');
    const submitBtn = document.getElementById('modal-submit-btn');

    if (mode === 'create') {
      titleHeader.innerText = 'Add New MCQ';
      form.action = '/admin/questions';
      form.reset();
      submitBtn.innerText = 'Save Question';
    } else if (mode === 'edit') {
      titleHeader.innerText = 'Edit MCQ Details';
      form.action = '/admin/questions/' + questionId;
      submitBtn.innerText = 'Save Changes';

      const qObj = questionsList.find(q => q._id === questionId);
      if (qObj) {
        document.getElementById('text').value = qObj.text;
        document.getElementById('optionA').value = qObj.options.A;
        document.getElementById('optionB').value = qObj.options.B;
        document.getElementById('optionC').value = qObj.options.C;
        document.getElementById('optionD').value = qObj.options.D;
        document.getElementById('correctAnswer').value = qObj.correctAnswer;
        document.getElementById('marks').value = qObj.marks;
        document.getElementById('negativeMarks').value = qObj.negativeMarks;
        document.getElementById('subject').value = qObj.subject;
      }
    }
    modal.style.display = 'flex';
  }

  function closeQuestionModal() {
    document.getElementById('question-modal').style.display = 'none';
  }

  function openImportModal() {
    document.getElementById('import-modal').style.display = 'flex';
    document.getElementById('import-feedback').style.display = 'none';
  }

  function closeImportModal() {
    document.getElementById('import-modal').style.display = 'none';
  }

  async function handleCSVImport(event) {
    event.preventDefault();
    const submitBtn = document.getElementById('import-submit-btn');
    const feedback = document.getElementById('import-feedback');
    const fileInput = document.getElementById('csvFile');

    if (fileInput.files.length === 0) return;

    submitBtn.disabled = true;
    feedback.className = 'alert alert-info mt-2';
    feedback.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Processing upload...';
    feedback.style.display = 'block';

    const formData = new FormData();
    formData.append('csvFile', fileInput.files[0]);

    try {
      const response = await fetch('/api/admin/questions/import', {
        method: 'POST',
        body: formData
      });
      const data = await response.json();
      
      if (data.success) {
        feedback.className = 'alert alert-success mt-2';
        feedback.innerHTML = `<i class="fa-solid fa-circle-check"></i> Success! Imported ${data.count} questions. Refreshing...`;
        setTimeout(() => {
          window.location.reload();
        }, 1500);
      } else {
        feedback.className = 'alert alert-danger mt-2';
        feedback.innerHTML = `<i class="fa-solid fa-circle-xmark"></i> Error: ${data.message || data.error}`;
        submitBtn.disabled = false;
      }
    } catch (err) {
      console.error(err);
      feedback.className = 'alert alert-danger mt-2';
      feedback.innerHTML = `<i class="fa-solid fa-circle-xmark"></i> Connection error. Try again.`;
      submitBtn.disabled = false;
    }
  }

  async function deleteQuestion(questionId) {
    if (confirm('Are you sure you want to delete this question? It will be removed from all exams.')) {
      try {
        const response = await fetch('/admin/questions/' + questionId, {
          method: 'DELETE'
        });
        const data = await response.json();
        if (data.success) {
          window.location.reload();
        } else {
          alert('Delete failed: ' + data.message);
        }
      } catch (err) {
        console.error(err);
        alert('An error occurred while deleting.');
      }
    }
  }
</script>

<%- include('../layouts/footer') %>
